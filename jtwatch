#!/usr/bin/env python3
"""
jtwatch
=======
Listen for WSJT-X UDP broadcasts, print CQ calls to stdout enriched with
entity / CQ-zone / country / grid info from cty.dat, optionally save as
newline-delimited JSON, and optionally load an ADIF logbook so that contacts
whose entity, CQ zone, or country have NOT been worked before are flagged as
NEEDED (with an ASCII BEL to ring the terminal bell).

Dependencies
------------
  None beyond the Python standard library.

First run
---------
  cty.dat (the AD1C Big CTY prefix database) is downloaded automatically from
  country-files.com and cached at ~/.jtwatch_cty.dat.
  Re-use that file on subsequent runs; refresh it by deleting the cache.

Usage
-----
  # Basic live monitor
  jtwatch

  # ADIF mode — bell + NEEDED flag for new entities/zones/countries
  jtwatch --adif ~/Documents/wsjtx_log.adi

  # Save every CQ record to a JSON-lines file
  jtwatch --save cq.jsonl

  # ADIF mode, only alert on new DXCC entities, save output
  jtwatch --adif ~/wsjtx_log.adi --no-need-cqz --no-need-country --save cq.jsonl

  # Show all decodes (not just CQ) with wall-clock timestamps
  jtwatch --raw --show-time

Options
-------
  --host HOST           UDP bind address           (default: 0.0.0.0)
  --port PORT           UDP port                   (default: 2237)
  --show-time           Prepend local wall-clock time HH:MM:SS to every line
  --raw                 Print ALL decoded messages, not just CQ
  --save FILE           Append each CQ record as a JSON line to FILE
  --cty PATH            Path to cty.dat            (default: ~/.jtwatch_cty.dat)
  --adif FILE           ADIF log file for NEEDED detection
  --no-need-entity      Disable DXCC-entity NEEDED check
  --no-need-cqz         Disable CQ-zone NEEDED check
  --no-need-country     Disable country-name NEEDED check
  --match-calls FILE [...]    File(s) of callsign regex patterns (one per line);
                              matching CQs are flagged *** MATCH *** and ring the bell
  --match-message FILE [...]  File(s) of decoded-message regex patterns (one per line);
                              matching messages are flagged *** MATCH *** and ring the bell
  --alert-command SCRIPT      Script to exec on NEEDED/MATCH events; alert message is arg 1.
                              Duplicate events (same call + same flags) are suppressed.
  --alert-ntfy TOPIC          POST NEEDED/MATCH alerts to ntfy.sh topic TOPIC.
                              Duplicate events are suppressed for the lifetime of the run.
  --pota                      Flag CQ POTA calls as MATCH (no file required).
  --sota                      Flag CQ SOTA calls as MATCH (no file required).
  --iota                      Flag CQ IOTA calls as MATCH (no file required).
  --call                      On NEEDED/MATCH events, prompt "Do you want to call <call>? [Y/n]".
                              Pressing Enter defaults to yes; times out to no after --call-timeout
                              seconds. Each callsign is prompted at most once per run.
  --call-timeout SECONDS      Seconds to wait for a response to the call prompt (default: 15)
  --color                     Colorize output with ANSI escape codes.
                              Signal fields are dimmed; callsign is bold; entity block is cyan;
                              worked contacts are green; NEEDED alerts are bold red;
                              MATCH alerts are bold yellow.
"""

