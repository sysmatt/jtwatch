# ══════════════════════════════════════════════════════════════════════════════
#  cty.dat parser
#  Parses the AD1C Big CTY prefix database (country-files.com/cty/cty.dat).
#  No external libraries required.
# ══════════════════════════════════════════════════════════════════════════════

_OVERRIDE_RE = re.compile(r"[\(\[\{<~][^\)\]\}>~]*[\)\]\}>~]")


def _strip_overrides(token: str) -> tuple:
    """
    Strip CQ/ITU/continent override annotations from a prefix token.
    Returns (clean_token, overrides_dict).

    Annotations in cty.dat:
      (nn)  = CQ zone override
      [nn]  = ITU zone override
      {XX}  = continent override
      <lat/lon>  = lat/lon override (ignored)
      ~nn   = time-zone offset (ignored)
    """
    overrides = {}
    m = re.search(r"\((\d+)\)", token)
    if m:
        overrides["cqz"] = int(m.group(1))
    m = re.search(r"\[(\d+)\]", token)
    if m:
        overrides["ituz"] = int(m.group(1))
    m = re.search(r"\{([A-Z]+)\}", token)
    if m:
        overrides["continent"] = m.group(1)
    clean = _OVERRIDE_RE.sub("", token).strip()
    return clean, overrides


class CtyDat:
    """
    Loads cty.dat and resolves amateur-radio callsigns to DXCC entity info.

    Each entity record in cty.dat looks like:
      Country Name:  CQz: ITUz: Cont: Lat: Long: UTC: Prefix;
          prefix1, prefix2, =EXACT1, =EXACT2, ...;

    We build:
      _exact    : dict  { "CALLSIGN" -> entity_dict }  for exact-match entries
      _prefixes : list  [ ("PREFIX", entity_dict) ]    sorted longest-first
    """

    def __init__(self):
        self._exact:    dict = {}
        self._prefixes: list = []

    # ── Loading ────────────────────────────────────────────────────────────────

    def load(self, path: Path) -> None:
        self._parse(path.read_text(encoding="utf-8", errors="replace"))

    def _parse(self, text: str) -> None:
        # Records start at a non-whitespace character (the country name)
        for record in re.split(r"\n(?=[A-Z*])", text):
            lines = record.strip().splitlines()
            if not lines:
                continue

            # Header line:  Name:CQz:ITUz:Cont:Lat:Lon:UTC:Prefix;
            parts = [p.strip() for p in lines[0].split(":")]
            if len(parts) < 8:
                continue
            try:
                base = {
                    "country":        parts[0].lstrip("*"),
                    "cqz":            int(parts[1]),
                    "ituz":           int(parts[2]),
                    "continent":      parts[3],
                    "latitude":       float(parts[4]),
                    "longitude":      -float(parts[5]),  # cty.dat stores W as +
                    "primary_prefix": parts[7].rstrip(";").strip(),
                }
            except (ValueError, IndexError):
                continue

            # Prefix/callsign lines (comma-separated, terminated by semicolon)
            body = " ".join(lines[1:]).split(";")[0]
            for raw in body.split(","):
                raw = raw.strip()
                if not raw:
                    continue
                exact = raw.startswith("=")
                clean, overrides = _strip_overrides(raw.lstrip("="))
                if not clean:
                    continue
                entry = {**base, **overrides}
                if exact:
                    self._exact[clean.upper()] = entry
                else:
                    self._prefixes.append((clean.upper(), entry))

        # Longest prefix first — greedy match gives best accuracy
        self._prefixes.sort(key=lambda x: len(x[0]), reverse=True)

    # ── Lookup ─────────────────────────────────────────────────────────────────

    def lookup(self, callsign: str) -> dict | None:
        """
        Return entity info dict for *callsign*, or None if not found.
        Handles portable/rover suffixes (W1ABC/P, HC2/DH1TW, VK9/W1ABC, etc.).
        """
        call = callsign.upper().strip()

        # Exact match (handles special callsigns like 3D2/R)
        if call in self._exact:
            return dict(self._exact[call])

        # Slash callsigns
        parts = call.split("/")
        if len(parts) == 2:
            a, b = parts
            portable = {"P", "M", "MM", "AM", "QRP", "QRPP", "A", "B"}
            if b in portable:
                call = a                       # W1ABC/P -> W1ABC
            elif a in portable:
                call = b                       # P/W1ABC -> W1ABC
            elif len(a) <= 3 and not a[-1].isdigit():
                # Short non-numeric prefix suggests country: HC2/DH1TW
                r = self._prefix_match(a)
                if r:
                    return r
                call = b
            else:
                # Keep the longer part
                call = a if len(a) >= len(b) else b

        return self._prefix_match(call)

    def _prefix_match(self, call: str) -> dict | None:
        for prefix, entry in self._prefixes:
            if call.startswith(prefix):
                return dict(entry)
        return None


def load_regex_patterns(file_paths: list) -> list:
    """Load compiled regex patterns from one or more files, one pattern per line.
    Blank lines and lines starting with '#' are ignored."""
    patterns = []
    for path_str in file_paths:
        p = Path(path_str)
        try:
            for i, raw in enumerate(p.read_text(encoding="utf-8").splitlines(), 1):
                line = raw.strip()
                if not line or line.startswith("#"):
                    continue
                try:
                    patterns.append(re.compile(line, re.IGNORECASE))
                except re.error as exc:
                    print(f"[match] {p.name}:{i}: invalid regex {line!r}: {exc}",
                          file=sys.stderr)
        except OSError as exc:
            print(f"[match] Cannot read {p}: {exc}", file=sys.stderr)
            sys.exit(1)
    return patterns


def _regex_matches(value: str, patterns: list) -> list:
    """Return pattern strings that match *value* (case-insensitive search)."""
    return [p.pattern for p in patterns if p.search(value)]


def _build_alert_msg(callsign, entity_info: dict,
                     needed_flags: list, match_flags: list) -> str:
    """Build a compact one-line summary for external alert delivery."""
    segments = [callsign or "?"]
    if entity_info:
        segments.append(f"{entity_info['entity']} CQ{entity_info['cq_zone']}")
    flag_parts = []
    if needed_flags:
        flag_parts.append("NEEDED: " + ", ".join(needed_flags))
    if match_flags:
        flag_parts.append("MATCH: " + ", ".join(match_flags))
    if flag_parts:
        segments.append("  ".join(flag_parts))
    return " | ".join(segments)


def _send_alerts(msg: str, args: argparse.Namespace) -> None:
    """Dispatch an alert message via --alert-command and/or --alert-ntfy."""
    if args.alert_command:
        try:
            subprocess.Popen([args.alert_command, msg])
        except Exception as exc:
            print(f"[alert-command] {exc}", file=sys.stderr)

    if args.alert_ntfy:
        try:
            req = urllib.request.Request(
                f"https://ntfy.sh/{args.alert_ntfy}",
                data=msg.encode("utf-8"),
                method="POST",
            )
            req.add_header("Title", "jtwatch")
            urllib.request.urlopen(req, timeout=10)
        except Exception as exc:
            print(f"[alert-ntfy] {exc}", file=sys.stderr)


def _encode_utf8(s: str) -> bytes:
    """Encode a string as a Qt QDataStream QString (big-endian length + UTF-8 bytes)."""
    if not s:
        return struct.pack(">I", 0xFFFFFFFF)
    b = s.encode("utf-8")
    return struct.pack(">I", len(b)) + b


def _send_reply(tx_sock, wsjt_addr: tuple, decoded: dict) -> None:
    """
    Send a WSJT-X Reply (Type 4) message to wsjt_addr.

    This is the protocol equivalent of double-clicking a decode in the WSJT-X
    UI: WSJT-X will set the DX callsign, generate the appropriate response
    message, and enable TX.

    Requires "Accept UDP requests" to be checked in WSJT-X
    Settings → Reporting.
    """
    buf = bytearray()
    buf += struct.pack(">III", MAGIC, 2, MSG_REPLY)   # magic, schema=2, type=Reply
    buf += _encode_utf8(decoded["id"])
    buf += struct.pack(">I",  decoded["time_ms"])
    buf += struct.pack(">i",  decoded["snr"])
    buf += struct.pack(">d",  decoded["dt"])
    buf += struct.pack(">I",  decoded["df"])
    buf += _encode_utf8(decoded["mode"])
    buf += _encode_utf8(decoded["message"])
    buf += struct.pack(">B",  1 if decoded.get("low_conf") else 0)
    buf += struct.pack(">B",  0)                      # Modifiers: none
    try:
        tx_sock.sendto(bytes(buf), wsjt_addr)
    except OSError as exc:
        print(f"[call] Reply send failed: {exc}", file=sys.stderr)


def _prompt_call(callsign: str, timeout: float) -> bool:
    """
    Write "Do you want to call <callsign>? [Y/n] " to stderr and wait up to
    *timeout* seconds for a keystroke.  Returns True on yes/Enter, False on
    no or timeout.  Silently returns False when stdin is not a TTY.
    """
    if not sys.stdin.isatty():
        return False

    sys.stderr.write(f"\nDo you want to call {callsign}? [Y/n] ")
    sys.stderr.flush()

    try:
        ready, _, _ = select.select([sys.stdin], [], [], timeout)
    except OSError:
        sys.stderr.write("\n")
        sys.stderr.flush()
        return False

    if ready:
        answer = sys.stdin.readline().strip().lower()
        return answer in ("", "y", "yes")

    sys.stderr.write("(timeout — no)\n")
    sys.stderr.flush()
    return False


def download_cty(path: Path) -> None:
    """Download cty.dat from country-files.com and save to *path*."""
    print(f"[cty.dat] Downloading from {CTY_DAT_URL} …", file=sys.stderr)
    req = urllib.request.Request(
        CTY_DAT_URL, headers={"User-Agent": "jtwatch/1.0"}
    )
    with urllib.request.urlopen(req, timeout=20) as resp:
        path.write_bytes(resp.read())
    print(f"[cty.dat] Saved to {path}", file=sys.stderr)


# ══════════════════════════════════════════════════════════════════════════════
#  ADIF parser + worked-log tracker
# ══════════════════════════════════════════════════════════════════════════════

_ADIF_FIELD_RE = re.compile(
    r"<([A-Za-z_][A-Za-z0-9_]*)(?::[^:>]*)?:(\d+)(?::[A-Za-z])?>",
    re.IGNORECASE,
)
_ADIF_EOH_RE = re.compile(r"<EOH>", re.IGNORECASE)
_ADIF_EOR_RE = re.compile(r"<EOR>", re.IGNORECASE)


def parse_adif(path: Path) -> list:
    """
    Parse an ADIF file and return a list of QSO dicts.
    Keys are lower-cased ADIF field names; values are stripped strings.
    Handles both ADIF 2 and ADIF 3 files, with or without a header.
    """
    text = path.read_text(encoding="utf-8", errors="replace")

    # Skip everything before the first <EOH>
    eoh  = _ADIF_EOH_RE.search(text)
    body = text[eoh.end():] if eoh else text

    qsos: list = []
    pos = 0
    current: dict = {}

    while pos < len(body):
        m   = _ADIF_FIELD_RE.search(body, pos)
        eor = _ADIF_EOR_RE.search(body, pos)

        # <EOR> closes the current record
        if eor and (not m or eor.start() < m.start()):
            if current:
                qsos.append(current)
                current = {}
            pos = eor.end()
            continue

        if not m:
            break

        field  = m.group(1).lower()
        flen   = int(m.group(2))
        vstart = m.end()
        current[field] = body[vstart : vstart + flen].strip()
        pos = vstart + flen

    if current:
        qsos.append(current)

    return qsos


class AdifLog:
    """
    Parses an ADIF file and builds three sets of what has already been worked:

      worked_dxcc    — primary prefixes  e.g. {"W", "DL", "VK", "JA"}
      worked_cqz     — CQ zone ints      e.g. {5, 14, 28, 29}
      worked_country — upper-cased country names  e.g. {"UNITED STATES", "GERMANY"}

    Sets are populated from explicit ADIF fields first; if a field is absent
    the callsign is resolved via cty.dat to fill in the blanks.

    The needed_flags() method checks an incoming entity_info dict against these
    sets and returns a list of human-readable NEEDED reason strings.
    """

    def __init__(self, path: Path, cty: CtyDat):
        self.path = path
        self.cty  = cty

        self.worked_dxcc:    set = set()
        self.worked_cqz:     set = set()
        self.worked_country: set = set()
        self.total_qsos = 0

        self._load()

    def _load(self) -> None:
        qsos = parse_adif(self.path)
        self.total_qsos = len(qsos)

        for q in qsos:
            call    = q.get("call", "").strip().upper()
            cqz_raw = (q.get("cqz") or q.get("cq_zone") or "").strip()
            country = (q.get("country") or q.get("entity") or "").strip().upper()

            # Populate from explicit ADIF fields
            try:
                self.worked_cqz.add(int(cqz_raw))
            except ValueError:
                pass

            if country:
                self.worked_country.add(country)

            # Fill missing fields via cty.dat lookup on the callsign
            if call:
                info = self.cty.lookup(call)
                if info:
                    self.worked_dxcc.add(info["primary_prefix"].upper())
                    if not cqz_raw:
                        self.worked_cqz.add(info["cqz"])
                    if not country:
                        self.worked_country.add(info["country"].upper())

        print(
            f"[adif] Loaded {self.total_qsos} QSOs from {self.path.name}\n"
            f"[adif]   {len(self.worked_dxcc)} DXCC entities worked\n"
            f"[adif]   {len(self.worked_cqz)} CQ zones worked\n"
            f"[adif]   {len(self.worked_country)} countries worked",
            file=sys.stderr,
        )

    def needed_flags(self, entity_info: dict, args: argparse.Namespace) -> list:
        """
        Return a list of NEEDED reason strings for *entity_info*.
        Empty list = everything already worked, or checks disabled.

        Possible entries:
          "NEW-DXCC(prefix)"    primary prefix not in worked_dxcc
          "NEW-CQZ(n)"          CQ zone not in worked_cqz
          "NEW-CTRY(name)"      country not in worked_country
        """
        flags = []
        prefix  = (entity_info.get("primary_prefix") or "").upper()
        cqz     = entity_info.get("cq_zone")           # int or "?"
        country = (entity_info.get("entity") or "").upper()

        if args.need_entity and prefix and prefix not in self.worked_dxcc:
            flags.append(f"NEW-DXCC({prefix})")

        if args.need_cqz and isinstance(cqz, int) and cqz not in self.worked_cqz:
            flags.append(f"NEW-CQZ({cqz})")

        if args.need_country and country and country not in self.worked_country:
            flags.append(f"NEW-CTRY({entity_info.get('entity', '?')})")

        return flags

    def worked_flags(self, entity_info: dict, args: argparse.Namespace) -> list:
        """Return which enabled categories in entity_info are already worked."""
        flags = []
        prefix  = (entity_info.get("primary_prefix") or "").upper()
        cqz     = entity_info.get("cq_zone")
        country = (entity_info.get("entity") or "").upper()

        if args.need_entity and prefix and prefix in self.worked_dxcc:
            flags.append("dxcc")
        if args.need_cqz and isinstance(cqz, int) and cqz in self.worked_cqz:
            flags.append("cqz")
        if args.need_country and country and country in self.worked_country:
            flags.append("country")

        return flags


# ══════════════════════════════════════════════════════════════════════════════
#  CQ message parser
# ══════════════════════════════════════════════════════════════════════════════

_GRID_RE = re.compile(r"\b([A-R]{2}\d{2}(?:[A-X]{2})?)\b", re.IGNORECASE)

# CQ [MODIFIER] CALLSIGN [GRID]
# MODIFIER is 2-5 alpha chars: DX, POTA, SOTA, etc.
_CQ_RE = re.compile(
    r"^CQ\s+"
    r"(?:(?P<modifier>[A-Z]{2,5})\s+)?"
    r"(?P<callsign>[A-Z0-9/]{3,})"
    r"(?:\s+(?P<grid>[A-R]{2}\d{2}(?:[A-X]{2})?))?\s*$",
    re.IGNORECASE,
)

# Known non-callsign modifiers that appear after CQ
_KNOWN_MODS = {
    "DX", "POTA", "SOTA", "IOTA", "WFF", "BOTA", "LOTA", "WWFF",
    "HF", "VHF", "UHF", "EME", "MSK", "FT8", "FT4", "599",
}


def parse_cq_message(msg: str) -> tuple:
    """
    Parse a WSJT-X CQ message string.
    Returns (callsign, gridsquare, modifier) — any element may be None.

    Examples:
      "CQ W1ABC FN42"       -> ("W1ABC", "FN42", None)
      "CQ DX K7XYZ DM41"   -> ("K7XYZ", "DM41", "DX")
      "CQ POTA N3ZZZ EN91" -> ("N3ZZZ", "EN91", "POTA")
      "CQ W1ABC"            -> ("W1ABC", None, None)
    """
    msg = msg.strip()
    if not msg.upper().startswith("CQ"):
        return None, None, None

    m = _CQ_RE.match(msg)
    if not m:
        return None, None, None

    modifier = (m.group("modifier") or "").upper()
    callsign = (m.group("callsign") or "").upper()
    grid     = (m.group("grid")     or "").upper() or None

    # If "modifier" contains a digit or isn't a known keyword, it's the callsign
    if modifier and (any(c.isdigit() for c in modifier) or modifier not in _KNOWN_MODS):
        callsign = modifier
        modifier = ""

    return callsign or None, grid, modifier or None


# ══════════════════════════════════════════════════════════════════════════════
#  Qt binary stream reader  (WSJT-X uses Qt's QDataStream, big-endian)
# ══════════════════════════════════════════════════════════════════════════════

class Reader:
    def __init__(self, data: bytes):
        self.data = data
        self.pos  = 0

    def _read(self, n: int) -> bytes:
        if self.pos + n > len(self.data):
            raise ValueError("Packet underflow")
        chunk = self.data[self.pos : self.pos + n]
        self.pos += n
        return chunk

    def u8(self)    -> int:   return struct.unpack(">B", self._read(1))[0]
    def u32(self)   -> int:   return struct.unpack(">I", self._read(4))[0]
    def i32(self)   -> int:   return struct.unpack(">i", self._read(4))[0]
    def f32(self)   -> float: return struct.unpack(">f", self._read(4))[0]
    def f64(self)   -> float: return struct.unpack(">d", self._read(8))[0]
    def bool_(self) -> bool:  return self.u8() != 0

    def utf8(self) -> str:
        """Qt QString: 4-byte length (0xFFFFFFFF = null/empty), then UTF-8 bytes."""
        n = self.u32()
        if n == 0xFFFFFFFF:
            return ""
        return self._read(n).decode("utf-8", errors="replace")


def parse_decode_msg(r: Reader) -> dict:
    """Parse a WSJT-X Decode message (type 2) from a Reader."""
    d = {
        "id":       r.utf8(),
        "new":      r.bool_(),
        "time_ms":  r.u32(),
        "snr":      r.i32(),
        "dt":       r.f32(),
        "df":       r.u32(),
        "mode":     r.utf8(),
        "message":  r.utf8(),
        "low_conf": r.bool_(),
    }
    try:
        d["off_air"] = r.bool_()   # schema version ≥ 3 only
    except ValueError:
        d["off_air"] = False
    return d


