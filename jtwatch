#  Packet handler
# ══════════════════════════════════════════════════════════════════════════════

def handle_packet(
    data:          bytes,
    args:          argparse.Namespace,
    cty:           CtyDat,
    adif_log,                   # AdifLog | None
    json_fh,                    # file object | None
    call_patterns: list,        # compiled regexes for --match-calls
    msg_patterns:  list,        # compiled regexes for --match-message
    alerted:       set,         # dedup set for external alerts (mutated in place)
    prompted:      set,         # callsigns already prompted this run (mutated in place)
    tx_sock,                    # unbound UDP socket for sending commands to WSJT-X
    wsjt_addr:     tuple,       # (host, port) of the WSJT-X instance that sent this packet
) -> None:
    """
    Decode one UDP datagram.  If it's a CQ (or --raw is set):
      • print a formatted line to stdout (with BELL prefix if NEEDED)
      • append a JSON record to json_fh if --save was given
    """
    if len(data) < 12:
        return False

    r = Reader(data)
    try:
        if r.u32() != MAGIC:
            return False
        r.u32()                        # schema version — not used
        if r.u32() != MSG_DECODE:
            return False
        decoded = parse_decode_msg(r)
    except (ValueError, struct.error):
        return False

    msg_text = decoded.get("message", "").strip()
    is_cq    = msg_text.upper().startswith("CQ")

    if not is_cq and not args.raw:
        return False

    # ── Parse CQ message ──────────────────────────────────────────────────────
    callsign = grid = modifier = None
    entity_info: dict = {}

    if is_cq:
        callsign, grid, modifier = parse_cq_message(msg_text)

        # Fallback: scan the whole message for a grid square
        if not grid:
            gm = _GRID_RE.search(msg_text)
            if gm:
                grid = gm.group(1).upper()

        # Entity lookup via cty.dat prefix table
        if callsign:
            raw = cty.lookup(callsign)
            if raw:
                entity_info = {
                    "primary_prefix": raw.get("primary_prefix", "?"),
                    "entity":         raw.get("country",        "?"),
                    "cq_zone":        raw.get("cqz",            "?"),
                    "itu_zone":       raw.get("ituz",           "?"),
                    "continent":      raw.get("continent",      "?"),
                }

    # ── NEEDED check (only when ADIF log is loaded) ────────────────────────────
    needed_flags: list = []
    if adif_log and is_cq and entity_info:
        needed_flags = adif_log.needed_flags(entity_info, args)
    is_needed = bool(needed_flags)

    # ── Pattern-match checks (--match-calls / --match-message) ────────────────
    match_flags: list = []
    if call_patterns and callsign:
        match_flags.extend(f"CALL:{m}" for m in _regex_matches(callsign, call_patterns))
    if msg_patterns and msg_text:
        match_flags.extend(f"MSG:{m}" for m in _regex_matches(msg_text, msg_patterns))
    is_match = bool(match_flags)

    # ── External alerts (--alert-command / --alert-ntfy) ──────────────────────
    if (is_needed or is_match) and (args.alert_command or args.alert_ntfy):
        alert_key = (callsign, frozenset(needed_flags + match_flags))
        if alert_key not in alerted:
            alerted.add(alert_key)
            _send_alerts(
                _build_alert_msg(callsign, entity_info, needed_flags, match_flags),
                args,
            )

    # ── Timestamps ────────────────────────────────────────────────────────────
    time_ms = decoded["time_ms"]
    hh = (time_ms // 3_600_000) % 24
    mm = (time_ms %  3_600_000) // 60_000
    ss = (time_ms %     60_000) //  1_000
    period_utc = f"{hh:02d}{mm:02d}{ss:02d}z"
    wall_utc   = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    snr  = decoded["snr"]
    dt   = decoded["dt"]
    df   = decoded["df"]
    mode = decoded["mode"] or "?"

    # ── Build the output line (fixed-width columns) ───────────────────────────
    color = args.color
    cols: list = []

    if args.show_time:
        cols.append(_col(f"[{datetime.now().strftime('%H:%M:%S')}]", _DIM, color))

    cols.append(_col(period_utc,           _DIM, color))
    cols.append(_col(f"{snr:+4d}",     _DIM, color))
    cols.append(_col(f"{dt:+6.1f}s",  _DIM, color))
    cols.append(_col(f"{df:5d}",       _DIM, color))
    cols.append(_col(f"{mode:<4}",     _DIM, color))

    cols.append(f"{msg_text:<{_W_MSG}}")             # _W_MSG chars, always padded

    # Callsign and grid are always emitted (blank when absent) so the entity
    # column stays at a consistent horizontal position on every line.
    call_col = callsign if (is_cq and callsign) else ""
    call_str = f"{call_col:<{_W_CALL}}"
    cols.append(_col(call_str, _BOLD, color) if call_col else call_str)

    grid_col = grid if grid else ""
    cols.append(f"{grid_col:<{_W_GRID}}")

    if entity_info:
        entity_str = (
            f"| {entity_info['entity']:<30}"
            f"  CQ{entity_info['cq_zone']:<3}"
            f" ITU{entity_info['itu_zone']:<3}"
            f" {entity_info['continent']:<2}"
        )
        cols.append(_col(entity_str, _CYN, color))

    # Status: NEEDED flags, worked indicator, and/or pattern-match flags
    status_parts: list = []
    if adif_log and is_cq:
        if needed_flags:
            s = f"*** NEEDED: {', '.join(needed_flags)} ***"
            status_parts.append(_col(s, _BRED, color))
        elif entity_info:
            wf = adif_log.worked_flags(entity_info, args)
            s = f"[worked {' '.join(wf)}]" if wf else "[worked]"
            status_parts.append(_col(s, _GRN, color))
    if match_flags:
        s = f"*** MATCH: {', '.join(match_flags)} ***"
        status_parts.append(_col(s, _BYEL, color))
    if status_parts:
        cols.append("  ".join(status_parts))

    line = "  ".join(cols)

    # Emit BELL before the line so it sounds as the text appears
    if is_needed or is_match:
        print(BELL + line, flush=True)
    else:
        print(line, flush=True)

    # ── Interactive call prompt (--call) ──────────────────────────────────────
    if (is_needed or is_match) and args.call and callsign and callsign not in prompted:
        prompted.add(callsign)
        if _prompt_call(callsign, args.call_timeout):
            sys.stderr.write(f"[call] Sending reply to {callsign} and enabling TX\n")
            sys.stderr.flush()
            _send_reply(tx_sock, wsjt_addr, decoded)

    # ── JSON record ───────────────────────────────────────────────────────────
    if json_fh and is_cq:
        record = {
            "wall_utc":       wall_utc,
            "period_utc":     period_utc,
            "snr_db":         snr,
            "dt_s":           round(dt, 2),
            "df_hz":          df,
            "mode":           mode,
            "message":        msg_text,
            "callsign":       callsign,
            "modifier":       modifier or None,
            "gridsquare":     grid or None,
            "primary_prefix": entity_info.get("primary_prefix"),
            "entity":         entity_info.get("entity"),
            "cq_zone":        entity_info.get("cq_zone"),
            "itu_zone":       entity_info.get("itu_zone"),
            "continent":      entity_info.get("continent"),
            "needed":         needed_flags if adif_log else None,
        }
        json_fh.write(json.dumps(record) + "\n")
        json_fh.flush()

    return True


# ══════════════════════════════════════════════════════════════════════════════
#  Entry point
# ══════════════════════════════════════════════════════════════════════════════

_HEADER_EVERY = 15


def _print_header(args: argparse.Namespace) -> None:
    """Print the column header and separator to stdout, matching actual data widths."""
    parts = []
    if args.show_time:
        parts.append(f"{'[time]':<10}")       # "[HH:MM:SS]" = 10 chars
    parts.append(f"{'HHMMSSZ':<7}")            # period_utc      = 7 chars
    parts.append(f"{'dB':>4}")                 # f"{snr:+4d}"    = 4 chars
    parts.append(f"{'dt(s)':>7}")              # f"{dt:+6.1f}s"  = 7 chars
    parts.append(f"{'Hz':>5}")                 # f"{df:5d}"      = 5 chars
    parts.append(f"{'mode':<4}")               # f"{mode:<4}"    = 4 chars
    parts.append(f"{'message':<{_W_MSG}}")
    parts.append(f"{'callsign':<{_W_CALL}}")
    parts.append(f"{'grid':<{_W_GRID}}")
    # entity cols: "| " + entity(30) + "  CQz  "(7) + " ITUz  "(7) + " ct"(3)
    parts.append(f"| {'entity':<30}  CQz   ITUz   ct")
    print("  ".join(parts), flush=True)
    print("-" * 112, flush=True)


def main() -> None:
    parser = argparse.ArgumentParser(
        description=(
            "Monitor WSJT-X CQ calls via UDP.\n"
            "Enriches output with DXCC entity / CQ zone / country / grid.\n"
            "With --adif, flags and bells NEEDED contacts not yet in your log."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
examples:
  jtwatch
  jtwatch --adif ~/Documents/wsjtx_log.adi
  jtwatch --adif ~/wsjtx_log.adi --save cq.jsonl
  jtwatch --adif ~/wsjtx_log.adi --no-need-cqz --no-need-country
  jtwatch --raw --show-time --port 2237
  jtwatch --match-calls watchlist.txt
  jtwatch --match-calls rare_dx.txt pota.txt --match-message sota.txt
        """,
    )

    # Network
    parser.add_argument("--host", default="0.0.0.0",
                        help="UDP bind address (default: 0.0.0.0)")
    parser.add_argument("--port", type=int, default=2237,
                        help="UDP port matching WSJT-X Settings → Reporting (default: 2237)")

    # Display
    parser.add_argument("--show-time", action="store_true",
                        help="Prepend local wall-clock HH:MM:SS to each line")
    parser.add_argument("--raw", action="store_true",
                        help="Print ALL decoded messages, not just CQ")

    # Output file
    parser.add_argument("--save", metavar="FILE",
                        help="Append each CQ record as a JSON line to FILE")

    # Data files
    parser.add_argument(
        "--cty", metavar="PATH", default=str(CTY_DAT_DEFAULT),
        help=(
            f"Path to cty.dat (default: {CTY_DAT_DEFAULT}). "
            "Downloaded automatically from country-files.com on first run."
        ),
    )
    parser.add_argument(
        "--adif", metavar="FILE",
        help=(
            "ADIF log file to compare against for NEEDED detection. "
            "Contacts whose DXCC entity, CQ zone, or country are NOT in the "
            "log are flagged *** NEEDED *** and trigger an ASCII bell (\\a)."
        ),
    )

    # NEEDED toggles — all on by default when --adif is provided
    parser.add_argument("--no-need-entity",  dest="need_entity",
                        action="store_false", default=True,
                        help="Disable NEEDED check for DXCC entity / primary prefix")
    parser.add_argument("--no-need-cqz",     dest="need_cqz",
                        action="store_false", default=True,
                        help="Disable NEEDED check for CQ zone number")
    parser.add_argument("--no-need-country", dest="need_country",
                        action="store_false", default=True,
                        help="Disable NEEDED check for country name")

    # Pattern matching
    parser.add_argument(
        "--match-calls", metavar="FILE", nargs="+",
        help="File(s) containing callsign regex patterns (one per line, # = comment). "
             "Matching CQs are flagged *** MATCH *** and ring the bell.",
    )
    parser.add_argument(
        "--match-message", metavar="FILE", nargs="+",
        help="File(s) containing full decoded-message regex patterns (one per line, # = comment). "
             "Matching messages are flagged *** MATCH *** and ring the bell.",
    )
    parser.add_argument("--pota", action="store_true",
                        help="Flag CQ POTA calls as *** MATCH *** (no file required).")
    parser.add_argument("--sota", action="store_true",
                        help="Flag CQ SOTA calls as *** MATCH *** (no file required).")
    parser.add_argument("--iota", action="store_true",
                        help="Flag CQ IOTA calls as *** MATCH *** (no file required).")

    # External alerting
    parser.add_argument(
        "--alert-command", metavar="SCRIPT",
        help="Script to execute on NEEDED/MATCH events; the alert message is passed as argument 1. "
             "Duplicate events (same callsign + same flags) are suppressed for this run.",
    )
    parser.add_argument(
        "--alert-ntfy", metavar="TOPIC",
        help="POST NEEDED/MATCH alerts to ntfy.sh topic TOPIC. "
             "Duplicate events are suppressed for this run.",
    )

    # Interactive call prompt
    parser.add_argument(
        "--call", action="store_true",
        help='On NEEDED/MATCH events, prompt "Do you want to call <callsign>? [Y/n]". '
             "Enter defaults to yes; times out to no after --call-timeout seconds. "
             "Each callsign is prompted at most once per run.",
    )
    parser.add_argument(
        "--call-timeout", metavar="SECONDS", type=float, default=15.0,
        help="Seconds to wait for a response to the --call prompt (default: 15).",
    )
    parser.add_argument(
        "--color", action="store_true",
        help="Colorize output with ANSI escape codes: signal fields dimmed, "
             "callsign bold, entity block cyan, worked contacts green, "
             "NEEDED alerts bold red, MATCH alerts bold yellow.",
    )

    args = parser.parse_args()

    # ── cty.dat ───────────────────────────────────────────────────────────────
    cty_path = Path(args.cty)
    if not cty_path.exists():
        try:
            download_cty(cty_path)
        except Exception as exc:
            print(f"[cty.dat] Download failed: {exc}", file=sys.stderr)
            print("[cty.dat] Continuing without entity lookup.", file=sys.stderr)

    cty = CtyDat()
    if cty_path.exists():
        try:
            cty.load(cty_path)
            print(
                f"[cty.dat] Loaded {len(cty._prefixes)} prefixes + "
                f"{len(cty._exact)} exact callsigns from {cty_path}",
                file=sys.stderr,
            )
        except Exception as exc:
            print(f"[cty.dat] Load error: {exc} — entity info will be blank.",
                  file=sys.stderr)
    else:
        print("[cty.dat] File not found — entity info will be blank.", file=sys.stderr)

    # ── ADIF log ──────────────────────────────────────────────────────────────
    adif_log  = None
    adif_path = None
    adif_mtime: float | None = None
    if args.adif:
        adif_path = Path(args.adif)
        if not adif_path.exists():
            print(f"[adif] File not found: {adif_path}", file=sys.stderr)
            sys.exit(1)
        try:
            adif_log   = AdifLog(adif_path, cty)
            adif_mtime = adif_path.stat().st_mtime
        except Exception as exc:
            print(f"[adif] Failed to load: {exc}", file=sys.stderr)
            sys.exit(1)

        checks = [n for flag, n in [
            (args.need_entity,  "DXCC entity"),
            (args.need_cqz,     "CQ zone"),
            (args.need_country, "country"),
        ] if flag]
        print(
            f"[adif] NEEDED checks active: {', '.join(checks) or 'none (all disabled)'}",
            file=sys.stderr,
        )
        print(
            "[adif] Bell (\\a) will sound and *** NEEDED *** will appear "
            "for qualifying contacts.",
            file=sys.stderr,
        )

    # ── Alert / prompt dedup state ────────────────────────────────────────────
    alerted:  set = set()   # (callsign, frozenset(flags)) keys already dispatched
    prompted: set = set()   # callsigns already shown the --call prompt this run

    # ── Pattern files ─────────────────────────────────────────────────────────
    call_patterns: list = []
    msg_patterns:  list = []
    if args.match_calls:
        call_patterns = load_regex_patterns(args.match_calls)
        print(
            f"[match-calls] {len(call_patterns)} pattern(s) loaded from "
            f"{', '.join(args.match_calls)}",
            file=sys.stderr,
        )
    if args.match_message:
        msg_patterns = load_regex_patterns(args.match_message)
        print(
            f"[match-message] {len(msg_patterns)} pattern(s) loaded from "
            f"{', '.join(args.match_message)}",
            file=sys.stderr,
        )
    for flag, keyword in ((args.pota, "POTA"), (args.sota, "SOTA"), (args.iota, "IOTA")):
        if flag:
            msg_patterns.append(re.compile(rf"\b{keyword}\b", re.IGNORECASE))
            print(f"[match-message] {keyword} pattern active", file=sys.stderr)

    # ── JSON output ───────────────────────────────────────────────────────────
    json_fh = None
    if args.save:
        try:
            json_fh = open(args.save, "a", encoding="utf-8")
            print(f"[save] Appending JSON records to: {args.save}", file=sys.stderr)
        except OSError as exc:
            print(f"[save] Cannot open {args.save}: {exc}", file=sys.stderr)
            sys.exit(1)

    # ── UDP sockets ───────────────────────────────────────────────────────────
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM, socket.IPPROTO_UDP)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEPORT, 1)
    except AttributeError:
        pass   # SO_REUSEPORT not available on Windows
    sock.bind((args.host, args.port))

    # Separate unbound socket for sending commands TO WSJT-X.
    # An ephemeral source port avoids SO_REUSEPORT ambiguity — packets sent
    # from this socket route to WSJT-X rather than looping back to ourselves.
    tx_sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM, socket.IPPROTO_UDP)

    # ── Startup banner ────────────────────────────────────────────────────────
    label = "all decodes" if args.raw else "CQ calls only"
    print(f"\nListening on {args.host}:{args.port}  [{label}]", file=sys.stderr)
    if adif_log:
        print(
            f"[adif] {adif_log.total_qsos} QSOs in log — "
            "bell will ring on NEEDED contacts.",
            file=sys.stderr,
        )
    if args.call:
        print(
            "[call] Interactive prompt enabled — will ask before calling on "
            "NEEDED/MATCH events.\n"
            "[call] WSJT-X must have Settings → Reporting → "
            "'Accept UDP requests' checked.",
            file=sys.stderr,
        )
    print()
    _print_header(args)

    # ── Main receive loop ─────────────────────────────────────────────────────
    line_count = 0
    try:
        while True:
            data, wsjt_addr = sock.recvfrom(65535)

            if adif_path is not None:
                try:
                    mtime = adif_path.stat().st_mtime
                    if mtime != adif_mtime:
                        adif_mtime = mtime
                        adif_log = AdifLog(adif_path, cty)
                        print("[adif] File changed — reloaded.", file=sys.stderr)
                except OSError:
                    pass

            printed = handle_packet(data, args, cty, adif_log, json_fh,
                                    call_patterns, msg_patterns, alerted, prompted,
                                    tx_sock, wsjt_addr)
            if printed:
                line_count += 1
                if line_count % _HEADER_EVERY == 0:
                    _print_header(args)
    except KeyboardInterrupt:
        print("\nStopped.", file=sys.stderr)
    finally:
        sock.close()
        tx_sock.close()
        if json_fh:
            json_fh.close()


if __name__ == "__main__":
    main()
