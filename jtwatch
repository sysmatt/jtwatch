# ══════════════════════════════════════════════════════════════════════════════
#  cty.dat parser
#  Parses the AD1C Big CTY prefix database (country-files.com/cty/cty.dat).
#  No external libraries required.
# ══════════════════════════════════════════════════════════════════════════════

_OVERRIDE_RE = re.compile(r"[\(\[\{<~][^\)\]\}>~]*[\)\]\}>~]")


def _strip_overrides(token: str) -> tuple:
    """
    Strip CQ/ITU/continent override annotations from a prefix token.
    Returns (clean_token, overrides_dict).

    Annotations in cty.dat:
      (nn)  = CQ zone override
      [nn]  = ITU zone override
      {XX}  = continent override
      <lat/lon>  = lat/lon override (ignored)
      ~nn   = time-zone offset (ignored)
    """
    overrides = {}
    m = re.search(r"\((\d+)\)", token)
    if m:
        overrides["cqz"] = int(m.group(1))
    m = re.search(r"\[(\d+)\]", token)
    if m:
        overrides["ituz"] = int(m.group(1))
    m = re.search(r"\{([A-Z]+)\}", token)
    if m:
        overrides["continent"] = m.group(1)
    clean = _OVERRIDE_RE.sub("", token).strip()
    return clean, overrides


class CtyDat:
    """
    Loads cty.dat and resolves amateur-radio callsigns to DXCC entity info.

    Each entity record in cty.dat looks like:
      Country Name:  CQz: ITUz: Cont: Lat: Long: UTC: Prefix;
          prefix1, prefix2, =EXACT1, =EXACT2, ...;

    We build:
      _exact    : dict  { "CALLSIGN" -> entity_dict }  for exact-match entries
      _prefixes : list  [ ("PREFIX", entity_dict) ]    sorted longest-first
    """

    def __init__(self):
        self._exact:    dict = {}
        self._prefixes: list = []

    # ── Loading ────────────────────────────────────────────────────────────────

    def load(self, path: Path) -> None:
        self._parse(path.read_text(encoding="utf-8", errors="replace"))

    def _parse(self, text: str) -> None:
        # Records start at a non-whitespace character (the country name)
        for record in re.split(r"\n(?=[A-Z*])", text):
            lines = record.strip().splitlines()
            if not lines:
                continue

            # Header line:  Name:CQz:ITUz:Cont:Lat:Lon:UTC:Prefix;
            parts = [p.strip() for p in lines[0].split(":")]
            if len(parts) < 8:
                continue
            try:
                base = {
                    "country":        parts[0].lstrip("*"),
                    "cqz":            int(parts[1]),
                    "ituz":           int(parts[2]),
                    "continent":      parts[3],
                    "latitude":       float(parts[4]),
                    "longitude":      -float(parts[5]),  # cty.dat stores W as +
                    "primary_prefix": parts[7].rstrip(";").strip(),
                }
            except (ValueError, IndexError):
                continue

            # Prefix/callsign lines (comma-separated, terminated by semicolon)
            body = " ".join(lines[1:]).split(";")[0]
            for raw in body.split(","):
                raw = raw.strip()
                if not raw:
                    continue
                exact = raw.startswith("=")
                clean, overrides = _strip_overrides(raw.lstrip("="))
                if not clean:
                    continue
                entry = {**base, **overrides}
                if exact:
                    self._exact[clean.upper()] = entry
                else:
                    self._prefixes.append((clean.upper(), entry))

        # Longest prefix first — greedy match gives best accuracy
        self._prefixes.sort(key=lambda x: len(x[0]), reverse=True)

    # ── Lookup ─────────────────────────────────────────────────────────────────

    def lookup(self, callsign: str) -> dict | None:
        """
        Return entity info dict for *callsign*, or None if not found.
        Handles portable/rover suffixes (W1ABC/P, HC2/DH1TW, VK9/W1ABC, etc.).
        """
        call = callsign.upper().strip()

        # Exact match (handles special callsigns like 3D2/R)
        if call in self._exact:
            return dict(self._exact[call])

        # Slash callsigns
        parts = call.split("/")
        if len(parts) == 2:
            a, b = parts
            portable = {"P", "M", "MM", "AM", "QRP", "QRPP", "A", "B"}
            if b in portable:
                call = a                       # W1ABC/P -> W1ABC
            elif a in portable:
                call = b                       # P/W1ABC -> W1ABC
            elif len(a) <= 3 and not a[-1].isdigit():
                # Short non-numeric prefix suggests country: HC2/DH1TW
                r = self._prefix_match(a)
                if r:
                    return r
                call = b
            else:
                # Keep the longer part
                call = a if len(a) >= len(b) else b

        return self._prefix_match(call)

    def _prefix_match(self, call: str) -> dict | None:
        for prefix, entry in self._prefixes:
            if call.startswith(prefix):
                return dict(entry)
        return None


class CycleTracker:
    """
    Counts total and CQ decodes per WSJT-X cycle and maintains running averages
    split by even/odd slot parity.

    Parity is determined from time_ms:
      FT8 (15 s cycles): slot = time_ms // 15000; even if slot % 2 == 0
      FT4  (7.5 s cycles): slot = time_ms //  7500; even if slot % 2 == 0
    Only new=True decodes are counted (replayed decodes are ignored).
    A STATS line is returned (not printed) when a cycle boundary is crossed.
    """

    _SLOT_MS = {"FT4": 7500}   # default 15000 ms (FT8 / all others)

    def __init__(self):
        self.current_time_ms: int | None = None
        self._parity: str = "even"
        self.cycle_total: int = 0
        self.cycle_cq:    int = 0
        # {parity: [total_sum, cq_sum, cycle_count]}
        self._sums: dict = {"even": [0, 0, 0], "odd": [0, 0, 0]}

    @staticmethod
    def _slot_parity(time_ms: int, mode: str) -> str:
        slot_ms = CycleTracker._SLOT_MS.get(mode, 15000)
        return "even" if (time_ms // slot_ms) % 2 == 0 else "odd"

    def _close_cycle(self) -> str:
        """Accumulate the finished cycle and return a formatted STATS line."""
        s = self._sums[self._parity]
        s[0] += self.cycle_total
        s[1] += self.cycle_cq
        s[2] += 1

        t = self.current_time_ms
        hh = (t // 3_600_000) % 24
        mm = (t %  3_600_000) // 60_000
        ss = (t %     60_000) //  1_000
        period = f"{hh:02d}{mm:02d}{ss:02d}z"

        ev, od = self._sums["even"], self._sums["odd"]
        all_n      = ev[2] + od[2]
        avg_dec    = (ev[0] + od[0]) / all_n if all_n else 0.0
        avg_cq     = (ev[1] + od[1]) / all_n if all_n else 0.0
        ev_avg_dec = ev[0] / ev[2] if ev[2] else 0.0
        ev_avg_cq  = ev[1] / ev[2] if ev[2] else 0.0
        od_avg_dec = od[0] / od[2] if od[2] else 0.0
        od_avg_cq  = od[1] / od[2] if od[2] else 0.0

        return (
            f"STATS: {period} [{self._parity}]"
            f"  decodes={self.cycle_total} cq={self.cycle_cq}"
            f"  avg: dec={avg_dec:.1f} cq={avg_cq:.1f}"
            f"  even: dec={ev_avg_dec:.1f} cq={ev_avg_cq:.1f}"
            f"  odd: dec={od_avg_dec:.1f} cq={od_avg_cq:.1f}"
        )

    def record(self, time_ms: int, is_cq: bool, is_new: bool, mode: str) -> str | None:
        """
        Record one decode. Returns a STATS line string when the previous cycle
        just closed, otherwise None. Replayed decodes (is_new=False) are ignored.
        """
        if not is_new:
            return None

        stats_line = None
        if self.current_time_ms is not None and time_ms != self.current_time_ms:
            stats_line = self._close_cycle()
            self.cycle_total = 0
            self.cycle_cq    = 0

        if self.current_time_ms is None or time_ms != self.current_time_ms:
            self.current_time_ms = time_ms
            self._parity = self._slot_parity(time_ms, mode)

        self.cycle_total += 1
        if is_cq:
            self.cycle_cq += 1

        return stats_line


def load_state_set(value: str) -> set:
    """
    Return a set of uppercase US state abbreviations from either a file path
    (one abbreviation per line, # = comment) or a comma-separated list.
    """
    p = Path(value)
    if p.is_file():
        states = set()
        for raw in p.read_text(encoding="utf-8").splitlines():
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            states.add(line.upper())
        return states
    return {s.strip().upper() for s in value.split(",") if s.strip()}


class HamdatLookup:
    """
    Read-only interface to a hamdat SQLite database for callsign → US state lookups.
    Results are cached in memory so repeated decodes of the same callsign hit the
    DB only once per run.
    """

    def __init__(self, db_path: Path):
        self.db_path = db_path
        self._conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
        self._cache: dict = {}

    def state(self, callsign: str) -> str | None:
        """Return the 2-letter US state code for an active license, or None."""
        call = callsign.upper().strip()
        if call in self._cache:
            return self._cache[call]
        row = self._conn.execute(
            """SELECT e.state
               FROM license_header h
               JOIN entity e ON e.unique_system_identifier = h.unique_system_identifier
                   AND (e.entity_type = 'L' OR e.entity_type = '')
               WHERE h.call_sign = ? AND h.license_status = 'A'
               ORDER BY h.id DESC LIMIT 1""",
            (call,),
        ).fetchone()
        result = (row[0] or "").strip().upper() or None if row else None
        self._cache[call] = result
        return result

    def close(self):
        self._conn.close()


def load_regex_patterns(file_paths: list) -> list:
    """Load compiled regex patterns from one or more files, one pattern per line.
    Blank lines and lines starting with '#' are ignored."""
    patterns = []
    for path_str in file_paths:
        p = Path(path_str)
        try:
            for i, raw in enumerate(p.read_text(encoding="utf-8").splitlines(), 1):
                line = raw.strip()
                if not line or line.startswith("#"):
                    continue
                try:
                    patterns.append(re.compile(line, re.IGNORECASE))
                except re.error as exc:
                    print(f"[match] {p.name}:{i}: invalid regex {line!r}: {exc}",
                          file=sys.stderr)
        except OSError as exc:
            print(f"[match] Cannot read {p}: {exc}", file=sys.stderr)
            sys.exit(1)
    return patterns


def _regex_matches(value: str, patterns: list) -> list:
    """Return pattern strings that match *value* (case-insensitive search)."""
    return [p.pattern for p in patterns if p.search(value)]


def _build_alert_msg(callsign, entity_info: dict,
                     needed_flags: list, match_flags: list) -> str:
    """Build a compact one-line summary for external alert delivery."""
    segments = [callsign or "?"]
    if entity_info:
        segments.append(f"{entity_info['entity']} CQ{entity_info['cq_zone']}")
    flag_parts = []
    if needed_flags:
        flag_parts.append("NEEDED: " + ", ".join(needed_flags))
    if match_flags:
        flag_parts.append("MATCH: " + ", ".join(match_flags))
    if flag_parts:
        segments.append("  ".join(flag_parts))
    return " | ".join(segments)


def _send_alerts(msg: str, args: argparse.Namespace) -> None:
    """Dispatch an alert message via --alert-command and/or --alert-ntfy."""
    if args.alert_command:
        try:
            subprocess.Popen([args.alert_command, msg])
        except Exception as exc:
            print(f"[alert-command] {exc}", file=sys.stderr)

    if args.alert_ntfy:
        try:
            req = urllib.request.Request(
                f"https://ntfy.sh/{args.alert_ntfy}",
                data=msg.encode("utf-8"),
                method="POST",
            )
            req.add_header("Title", "jtwatch")
            urllib.request.urlopen(req, timeout=10)
        except Exception as exc:
            print(f"[alert-ntfy] {exc}", file=sys.stderr)


def _encode_utf8(s: str) -> bytes:
    """Encode a string as a Qt QDataStream QString (big-endian length + UTF-8 bytes)."""
    if not s:
        return struct.pack(">I", 0xFFFFFFFF)
    b = s.encode("utf-8")
    return struct.pack(">I", len(b)) + b


def _send_reply(tx_sock, wsjt_addr: tuple, decoded: dict) -> None:
    """
    Send a WSJT-X Reply (Type 4) message to wsjt_addr.

    This is the protocol equivalent of double-clicking a decode in the WSJT-X
    UI: WSJT-X will set the DX callsign, generate the appropriate response
    message, and enable TX.

    Requires "Accept UDP requests" to be checked in WSJT-X
    Settings → Reporting.
    """
    buf = bytearray()
    buf += struct.pack(">III", MAGIC, 2, MSG_REPLY)   # magic, schema=2, type=Reply
    buf += _encode_utf8(decoded["id"])
    buf += struct.pack(">I",  decoded["time_ms"])
    buf += struct.pack(">i",  decoded["snr"])
    buf += struct.pack(">d",  decoded["dt"])
    buf += struct.pack(">I",  decoded["df"])
    buf += _encode_utf8(decoded["mode"])
    buf += _encode_utf8(decoded["message"])
    buf += struct.pack(">B",  1 if decoded.get("low_conf") else 0)
    buf += struct.pack(">B",  0)                      # Modifiers: none
    try:
        tx_sock.sendto(bytes(buf), wsjt_addr)
    except OSError as exc:
        print(f"[call] Reply send failed: {exc}", file=sys.stderr)


def _prompt_call(callsign: str, timeout: float) -> bool:
    """
    Write "Do you want to call <callsign>? [Y/n] " to stderr and wait up to
    *timeout* seconds for a keystroke.  Returns True on yes/Enter, False on
    no or timeout.  Silently returns False when stdin is not a TTY.
    """
    if not sys.stdin.isatty():
        return False

    sys.stderr.write(f"\nDo you want to call {callsign}? [Y/n] ")
    sys.stderr.flush()

    try:
        ready, _, _ = select.select([sys.stdin], [], [], timeout)
    except OSError:
        sys.stderr.write("\n")
        sys.stderr.flush()
        return False

    if ready:
        answer = sys.stdin.readline().strip().lower()
        return answer in ("", "y", "yes")

    sys.stderr.write("(timeout — no)\n")
    sys.stderr.flush()
    return False


def download_cty(path: Path) -> None:
    """Download cty.dat from country-files.com and save to *path*."""
    print(f"[cty.dat] Downloading from {CTY_DAT_URL} …", file=sys.stderr)
    req = urllib.request.Request(
        CTY_DAT_URL, headers={"User-Agent": "jtwatch/1.0"}
    )
    with urllib.request.urlopen(req, timeout=20) as resp:
        path.write_bytes(resp.read())
    print(f"[cty.dat] Saved to {path}", file=sys.stderr)


# ══════════════════════════════════════════════════════════════════════════════
#  ADIF parser + worked-log tracker
# ══════════════════════════════════════════════════════════════════════════════

_ADIF_FIELD_RE = re.compile(
    r"<([A-Za-z_][A-Za-z0-9_]*)(?::[^:>]*)?:(\d+)(?::[A-Za-z])?>",
    re.IGNORECASE,
)
_ADIF_EOH_RE = re.compile(r"<EOH>", re.IGNORECASE)
_ADIF_EOR_RE = re.compile(r"<EOR>", re.IGNORECASE)


def parse_adif(path: Path) -> list:
    """
    Parse an ADIF file and return a list of QSO dicts.
    Keys are lower-cased ADIF field names; values are stripped strings.
    Handles both ADIF 2 and ADIF 3 files, with or without a header.
    """
    text = path.read_text(encoding="utf-8", errors="replace")

    # Skip everything before the first <EOH>
    eoh  = _ADIF_EOH_RE.search(text)
    body = text[eoh.end():] if eoh else text

    qsos: list = []
    pos = 0
    current: dict = {}

    while pos < len(body):
        m   = _ADIF_FIELD_RE.search(body, pos)
        eor = _ADIF_EOR_RE.search(body, pos)

        # <EOR> closes the current record
        if eor and (not m or eor.start() < m.start()):
            if current:
                qsos.append(current)
                current = {}
            pos = eor.end()
            continue

        if not m:
            break

        field  = m.group(1).lower()
        flen   = int(m.group(2))
        vstart = m.end()
        current[field] = body[vstart : vstart + flen].strip()
        pos = vstart + flen

    if current:
        qsos.append(current)

    return qsos


class AdifLog:
    """
    Parses an ADIF file and builds three sets of what has already been worked:

      worked_dxcc    — primary prefixes  e.g. {"W", "DL", "VK", "JA"}
      worked_cqz     — CQ zone ints      e.g. {5, 14, 28, 29}
      worked_country — upper-cased country names  e.g. {"UNITED STATES", "GERMANY"}

    Sets are populated from explicit ADIF fields first; if a field is absent
    the callsign is resolved via cty.dat to fill in the blanks.

    The needed_flags() method checks an incoming entity_info dict against these
    sets and returns a list of human-readable NEEDED reason strings.
    """

    def __init__(self, path: Path, cty: CtyDat):
        self.path = path
        self.cty  = cty

        self.worked_calls:   set = set()
        self.worked_grids:   set = set()
        self.worked_dxcc:    set = set()
        self.worked_cqz:     set = set()
        self.worked_country: set = set()
        self.total_qsos = 0

        self._load()

    def _load(self) -> None:
        qsos = parse_adif(self.path)
        self.total_qsos = len(qsos)

        for q in qsos:
            call    = q.get("call", "").strip().upper()
            cqz_raw = (q.get("cqz") or q.get("cq_zone") or "").strip()
            country = (q.get("country") or q.get("entity") or "").strip().upper()
            # Truncate to 4 chars — FT8 transmits 4-char grids; 6-char ADIF values match too
            grid    = q.get("gridsquare", "").strip().upper()[:4]

            # Populate from explicit ADIF fields
            try:
                self.worked_cqz.add(int(cqz_raw))
            except ValueError:
                pass

            if country:
                self.worked_country.add(country)

            if grid:
                self.worked_grids.add(grid)

            # Fill missing fields via cty.dat lookup on the callsign
            if call:
                self.worked_calls.add(call)
                info = self.cty.lookup(call)
                if info:
                    self.worked_dxcc.add(info["primary_prefix"].upper())
                    if not cqz_raw:
                        self.worked_cqz.add(info["cqz"])
                    if not country:
                        self.worked_country.add(info["country"].upper())

        print(
            f"[adif] Loaded {self.total_qsos} QSOs from {self.path.name}\n"
            f"[adif]   {len(self.worked_calls)} unique callsigns worked\n"
            f"[adif]   {len(self.worked_grids)} grid squares worked\n"
            f"[adif]   {len(self.worked_dxcc)} DXCC entities worked\n"
            f"[adif]   {len(self.worked_cqz)} CQ zones worked\n"
            f"[adif]   {len(self.worked_country)} countries worked",
            file=sys.stderr,
        )

    def needed_flags(self, entity_info: dict, args: argparse.Namespace) -> list:
        """
        Return a list of NEEDED reason strings for *entity_info*.
        Empty list = everything already worked, or checks disabled.

        Possible entries:
          "NEW-DXCC(prefix)"    primary prefix not in worked_dxcc
          "NEW-CQZ(n)"          CQ zone not in worked_cqz
          "NEW-CTRY(name)"      country not in worked_country
        """
        flags = []
        prefix  = (entity_info.get("primary_prefix") or "").upper()
        cqz     = entity_info.get("cq_zone")           # int or "?"
        country = (entity_info.get("entity") or "").upper()

        if args.need_entity and prefix and prefix not in self.worked_dxcc:
            flags.append(f"NEW-DXCC({prefix})")

        if args.need_cqz and isinstance(cqz, int) and cqz not in self.worked_cqz:
            flags.append(f"NEW-CQZ({cqz})")

        if args.need_country and country and country not in self.worked_country:
            flags.append(f"NEW-CTRY({entity_info.get('entity', '?')})")

        return flags

    def worked_flags(self, entity_info: dict, args: argparse.Namespace) -> list:
        """Return which enabled categories in entity_info are already worked."""
        flags = []
        prefix  = (entity_info.get("primary_prefix") or "").upper()
        cqz     = entity_info.get("cq_zone")
        country = (entity_info.get("entity") or "").upper()

        if args.need_entity and prefix and prefix in self.worked_dxcc:
            flags.append("dxcc")
        if args.need_cqz and isinstance(cqz, int) and cqz in self.worked_cqz:
            flags.append("cqz")
        if args.need_country and country and country in self.worked_country:
            flags.append("country")

        return flags


# ══════════════════════════════════════════════════════════════════════════════
#  CQ message parser
# ══════════════════════════════════════════════════════════════════════════════

_GRID_RE = re.compile(r"\b([A-R]{2}\d{2}(?:[A-X]{2})?)\b", re.IGNORECASE)

# CQ [MODIFIER] CALLSIGN [GRID]
# MODIFIER is 1-13 alpha chars: DX, POTA, SOTA, JA, NA, contest names, etc.
# CALLSIGN must contain at least one digit — a universal property of amateur callsigns.
# This lets the regex distinguish geo/contest qualifiers (all-alpha) from callsigns
# without a static list, so "CQ JA W1ABC" correctly identifies W1ABC, not JA.
_CQ_RE = re.compile(
    r"^CQ\s+"
    r"(?:(?P<modifier>[A-Z]{1,13})\s+)?"
    r"(?P<callsign>(?=[A-Z0-9/]*\d)[A-Z0-9/]{3,})"
    r"(?:\s+(?P<grid>[A-R]{2}\d{2}(?:[A-X]{2})?))?\s*$",
    re.IGNORECASE,
)


def parse_cq_message(msg: str) -> tuple:
    """
    Parse a WSJT-X CQ message string.
    Returns (callsign, gridsquare, modifier) — any element may be None.

    Examples:
      "CQ W1ABC FN42"       -> ("W1ABC", "FN42", None)
      "CQ DX K7XYZ DM41"   -> ("K7XYZ", "DM41", "DX")
      "CQ POTA N3ZZZ EN91" -> ("N3ZZZ", "EN91", "POTA")
      "CQ JA W1ABC FN42"   -> ("W1ABC", "FN42", "JA")
      "CQ W1ABC"            -> ("W1ABC", None, None)
    """
    msg = msg.strip()
    if not msg.upper().startswith("CQ"):
        return None, None, None

    m = _CQ_RE.match(msg)
    if not m:
        return None, None, None

    modifier = (m.group("modifier") or "").upper()
    callsign = (m.group("callsign") or "").upper()
    grid     = (m.group("grid")     or "").upper() or None

    return callsign or None, grid, modifier or None


# ══════════════════════════════════════════════════════════════════════════════
#  Qt binary stream reader  (WSJT-X uses Qt's QDataStream, big-endian)
# ══════════════════════════════════════════════════════════════════════════════

class Reader:
    def __init__(self, data: bytes):
        self.data = data
        self.pos  = 0

    def _read(self, n: int) -> bytes:
        if self.pos + n > len(self.data):
            raise ValueError("Packet underflow")
        chunk = self.data[self.pos : self.pos + n]
        self.pos += n
        return chunk

    def u8(self)    -> int:   return struct.unpack(">B", self._read(1))[0]
    def u32(self)   -> int:   return struct.unpack(">I", self._read(4))[0]
    def i32(self)   -> int:   return struct.unpack(">i", self._read(4))[0]
    def f32(self)   -> float: return struct.unpack(">f", self._read(4))[0]
    def f64(self)   -> float: return struct.unpack(">d", self._read(8))[0]
    def bool_(self) -> bool:  return self.u8() != 0

    def utf8(self) -> str:
        """Qt QString: 4-byte length (0xFFFFFFFF = null/empty), then UTF-8 bytes."""
        n = self.u32()
        if n == 0xFFFFFFFF:
            return ""
        return self._read(n).decode("utf-8", errors="replace")


def parse_decode_msg(r: Reader) -> dict:
    """Parse a WSJT-X Decode message (type 2) from a Reader."""
    d = {
        "id":       r.utf8(),
        "new":      r.bool_(),
        "time_ms":  r.u32(),
        "snr":      r.i32(),
        "dt":       r.f64(),
        "df":       r.u32(),
        "mode":     r.utf8(),
        "message":  r.utf8(),
        "low_conf": r.bool_(),
    }
    try:
        d["off_air"] = r.bool_()   # schema version ≥ 3 only
    except ValueError:
        d["off_air"] = False
    return d


# ══════════════════════════════════════════════════════════════════════════════
#  Packet handler
# ══════════════════════════════════════════════════════════════════════════════

def handle_packet(
    data:          bytes,
    args:          argparse.Namespace,
    cty:           CtyDat,
    adif_log,                   # AdifLog | None
    json_fh,                    # file object | None
    call_patterns: list,        # compiled regexes for --match-calls
    msg_patterns:  list,        # compiled regexes for --match-message
    state_set:     set,         # uppercase state abbreviations for --match-state
    hamdat,                     # HamdatLookup | None
    cycle_tracker,              # CycleTracker | None
    alerted:       set,         # dedup set for external alerts (mutated in place)
    prompted:      set,         # callsigns already prompted this run (mutated in place)
    tx_sock,                    # unbound UDP socket for sending commands to WSJT-X
    wsjt_addr:     tuple,       # (host, port) of the WSJT-X instance that sent this packet
) -> None:
    """
    Decode one UDP datagram.  If it's a CQ (or --raw is set):
      • print a formatted line to stdout (with BELL prefix if NEEDED)
      • append a JSON record to json_fh if --save was given
    """
    if len(data) < 12:
        return False

    r = Reader(data)
    try:
        if r.u32() != MAGIC:
            return False
        schema = r.u32()
        if r.u32() != MSG_DECODE:
            return False
        decoded = parse_decode_msg(r)
    except (ValueError, struct.error):
        return False

    if args.debug:
        print(
            f"[debug] schema={schema}  len={len(data)}\n"
            f"[debug] hex: {data.hex()}\n"
            f"[debug] id={decoded['id']!r}  new={decoded['new']}  "
            f"time_ms={decoded['time_ms']}  snr={decoded['snr']}\n"
            f"[debug] dt={decoded['dt']:.3f}  df={decoded['df']}  "
            f"mode={decoded['mode']!r}  message={decoded['message']!r}\n"
            f"[debug] low_conf={decoded['low_conf']}  off_air={decoded['off_air']}",
            file=sys.stderr,
        )

    msg_text = decoded.get("message", "").strip()
    is_cq    = msg_text.upper().startswith("CQ")
    mode     = _MODE_NAMES.get(decoded["mode"], decoded["mode"]) or "?"

    # ── Cycle stats (counts every decode, CQ or not) ──────────────────────────
    if cycle_tracker is not None:
        stats_line = cycle_tracker.record(decoded["time_ms"], is_cq, decoded["new"], mode)
        if stats_line:
            print(stats_line, flush=True)

    if not is_cq and not args.raw:
        return False

    # ── Parse CQ message ──────────────────────────────────────────────────────
    callsign = grid = modifier = None
    entity_info: dict = {}

    if is_cq:
        callsign, grid, modifier = parse_cq_message(msg_text)

        # Fallback: scan the whole message for a grid square
        if not grid:
            gm = _GRID_RE.search(msg_text)
            if gm:
                grid = gm.group(1).upper()

        # Entity lookup via cty.dat prefix table
        if callsign:
            raw = cty.lookup(callsign)
            if raw:
                entity_info = {
                    "primary_prefix": raw.get("primary_prefix", "?"),
                    "entity":         raw.get("country",        "?"),
                    "cq_zone":        raw.get("cqz",            "?"),
                    "itu_zone":       raw.get("ituz",           "?"),
                    "continent":      raw.get("continent",      "?"),
                }

    # ── NEEDED check (only when ADIF log is loaded) ────────────────────────────
    needed_flags: list = []
    if adif_log and is_cq and entity_info:
        needed_flags = adif_log.needed_flags(entity_info, args)
    is_needed = bool(needed_flags)

    # ── Pattern-match checks (--match-calls / --match-message / --match-state) ─
    match_flags: list = []
    if call_patterns and callsign:
        match_flags.extend(f"CALL:{m}" for m in _regex_matches(callsign, call_patterns))
    if msg_patterns and msg_text:
        match_flags.extend(f"MSG:{m}" for m in _regex_matches(msg_text, msg_patterns))
    station_state: str | None = None
    if hamdat and callsign:
        station_state = hamdat.state(callsign)
        if state_set and station_state and station_state in state_set:
            match_flags.append(f"STATE:{station_state}")
    is_match = bool(match_flags)

    # ── External alerts (--alert-command / --alert-ntfy) ──────────────────────
    if (is_needed or is_match) and (args.alert_command or args.alert_ntfy):
        alert_key = (callsign, frozenset(needed_flags + match_flags))
        if alert_key not in alerted:
            alerted.add(alert_key)
            _send_alerts(
                _build_alert_msg(callsign, entity_info, needed_flags, match_flags),
                args,
            )

    # ── Timestamps ────────────────────────────────────────────────────────────
    time_ms = decoded["time_ms"]
    hh = (time_ms // 3_600_000) % 24
    mm = (time_ms %  3_600_000) // 60_000
    ss = (time_ms %     60_000) //  1_000
    period_utc = f"{hh:02d}{mm:02d}{ss:02d}z"
    wall_utc   = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    snr  = decoded["snr"]
    dt   = decoded["dt"]
    df   = decoded["df"]

    # ── Build the output line (fixed-width columns) ───────────────────────────
    color = args.color
    cols: list = []

    if args.show_time:
        cols.append(_col(f"[{datetime.now().strftime('%H:%M:%S')}]", _DIM, color))

    cols.append(_col(period_utc,           _DIM, color))
    cols.append(_col(f"{snr:+4d}",     _DIM, color))
    cols.append(_col(f"{dt:+6.1f}s",  _DIM, color))
    cols.append(_col(f"{df:5d}",       _DIM, color))
    cols.append(_col(f"{mode:<4}",     _DIM, color))

    cols.append(f"{msg_text:<{_W_MSG}}")             # _W_MSG chars, always padded

    # Callsign and grid are always emitted (blank when absent) so the entity
    # column stays at a consistent horizontal position on every line.
    call_col    = callsign if (is_cq and callsign) else ""
    call_str    = f"{call_col:<{_W_CALL}}"
    call_worked = bool(adif_log and call_col and call_col in adif_log.worked_calls)
    if call_col:
        call_color = _BGRN if call_worked else _BOLD
        cols.append(_col(call_str, call_color, color))
    else:
        cols.append(call_str)

    grid_col    = grid if grid else ""
    grid_str    = f"{grid_col:<{_W_GRID}}"
    grid_worked = bool(adif_log and grid_col and grid_col[:4] in adif_log.worked_grids)
    cols.append(_col(grid_str, _GRN, color) if (grid_worked and grid_col) else grid_str)

    if hamdat and is_cq:
        cols.append(f"{station_state or '':<2}")

    if entity_info:
        em1 = em2 = em3 = ""
        if adif_log and is_cq:
            wf = set(adif_log.worked_flags(entity_info, args))
            if args.need_entity:
                em1 = "✅" if "dxcc"    in wf else "❌"
            if args.need_cqz:
                em2 = "✅" if "cqz"     in wf else "❌"
            if args.need_country:
                em3 = "✅" if "country" in wf else "❌"
        entity_str = (
            f"| {entity_info['entity']:<30}"
            f"  {em1}CQ{entity_info['cq_zone']:<3}"
            f" {em2}ITU{entity_info['itu_zone']:<3}"
            f" {em3}{entity_info['continent']:<2}"
        )
        cols.append(_col(entity_str, _CYN, color))

    line = "  ".join(cols)

    # NEEDED / MATCH alerts go on a second indented line
    alert_parts: list = []
    if adif_log and is_cq and needed_flags:
        alert_parts.append(_col(f"*** NEEDED: {', '.join(needed_flags)} ***", _BRED, color))
    if match_flags:
        alert_parts.append(_col(f"*** MATCH: {', '.join(match_flags)} ***", _BYEL, color))

    # Emit BELL before the line so it sounds as the text appears
    if is_needed or is_match:
        print(BELL + line, flush=True)
    else:
        print(line, flush=True)
    if alert_parts:
        print("  " + "  ".join(alert_parts), flush=True)

    # ── Interactive call prompt (--call) ──────────────────────────────────────
    if (is_needed or is_match) and args.call and callsign and callsign not in prompted:
        prompted.add(callsign)
        if _prompt_call(callsign, args.call_timeout):
            sys.stderr.write(f"[call] Sending reply to {callsign} and enabling TX\n")
            sys.stderr.flush()
            _send_reply(tx_sock, wsjt_addr, decoded)

    # ── JSON record ───────────────────────────────────────────────────────────
    if json_fh and is_cq:
        record = {
            "wall_utc":       wall_utc,
            "period_utc":     period_utc,
            "snr_db":         snr,
            "dt_s":           round(dt, 2),
            "df_hz":          df,
            "mode":           mode,
            "message":        msg_text,
            "callsign":       callsign,
            "modifier":       modifier or None,
            "gridsquare":     grid or None,
            "primary_prefix": entity_info.get("primary_prefix"),
            "entity":         entity_info.get("entity"),
            "cq_zone":        entity_info.get("cq_zone"),
            "itu_zone":       entity_info.get("itu_zone"),
            "continent":      entity_info.get("continent"),
            "needed":         needed_flags if adif_log else None,
        }
        json_fh.write(json.dumps(record) + "\n")
        json_fh.flush()

    return True


